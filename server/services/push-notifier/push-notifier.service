[Unit]
Description=Have You Fed The Dog - push notification relay
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/haveyoufedthedog/push-notifier
ExecStart=/usr/bin/node index.js
Restart=on-failure
RestartSec=5
Environment=PORT=3055
# PB superuser creds for the overdue cron (optional; see .env.example).
EnvironmentFile=-/opt/haveyoufedthedog/push-notifier/.env

[Install]
WantedBy=multi-user.target

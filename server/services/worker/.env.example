# Copy to /opt/haveyoufedthedog/worker/.env on the server (never
# commit the real one). Enables the overdue-chore cron - without these
# the service still relays hook pushes, but sends no overdue nudges.
PB_URL=http://127.0.0.1:8090
PB_SUPERUSER_EMAIL=cron@haveyoufedthedog.com
PB_SUPERUSER_PASSWORD=change-me

# In-app purchase verification (Android). Without these the service still
# relays pushes and runs the cron; it just rejects Android purchase checks.
# ANDROID_PACKAGE_NAME is the app's applicationId in Play.
# PLAY_SERVICE_ACCOUNT points at the dedicated Play Developer API service
# account JSON (deployed out-of-band, never committed). Defaults to
# ./play-service-account.json next to index.js if unset.
ANDROID_PACKAGE_NAME=com.haveyoufedthedog
PLAY_SERVICE_ACCOUNT=/opt/haveyoufedthedog/worker/play-service-account.json
